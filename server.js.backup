const express = require('express');
const path = require('path');
const session = require('express-session');
const bodyParser = require('body-parser');
const compression = require('compression');
const helmet = require('helmet');
const dotenv = require('dotenv');

// Cargar variables de entorno
dotenv.config();

const app = express();
const PORT = process.env.PORT || 3000;

// Middleware de seguridad
app.use(helmet({
    contentSecurityPolicy: false, // Deshabilitado para desarrollo
}));

// Compresión de respuestas
app.use(compression());

// Parseo de cuerpos de peticiones
app.use(bodyParser.json());
app.use(bodyParser.urlencoded({ extended: true }));

// Configuración de sesiones
app.use(session({
    secret: process.env.SESSION_SECRET || 'gtu-secret-key',
    resave: false,
    saveUninitialized: true,
    cookie: { 
        secure: process.env.NODE_ENV === 'production',
        maxAge: 30 * 60 * 1000 // 30 minutos
    }
}));

// Archivos estáticos
app.use('/css', express.static(path.join(__dirname, 'public/css')));
app.use('/js', express.static(path.join(__dirname, 'public/js')));
app.use('/assets', express.static(path.join(__dirname, 'public/assets')));

// Configuración de EJS
app.set('view engine', 'ejs');
app.set('views', path.join(__dirname, 'views'));

// Middleware para pasar usuario a todas las vistas
app.use((req, res, next) => {
    res.locals.user = req.session.user || null;
    res.locals.currentPage = req.path;
    next();
});

// Rutas principales
app.get('/', (req, res) => {
    if (req.session.user) {
        res.redirect('/pages/dashboard');
    } else {
        res.redirect('/pages/login');
    }
});

// ============= PÁGINAS =============

// Login
app.get('/pages/login', (req, res) => {
    res.render('pages/login', { 
        title: 'GTU Dashboard - Login',
        error: null 
    });
});

app.post('/api/login', (req, res) => {
    const { username, password, role } = req.body;
    
    // Simulación de autenticación (igual que en auth.js)
    const users = {
        superadmin: [
            { username: 'admin', password: 'admin123', name: 'Super Admin', role: 'superadmin' },
            { username: 'developer', password: 'dev123', name: 'Desarrollador', role: 'superadmin' }
        ],
        admin: [
            { username: 'directora', password: 'escuela123', name: 'Directora García', role: 'admin' },
            { username: 'coordinador', password: 'coord123', name: 'Coordinador López', role: 'admin' }
        ],
        asesor: [
            { username: 'asesor', password: 'ver123', name: 'Asesor Pérez', role: 'asesor' },
            { username: 'consultor', password: 'view123', name: 'Consultor Martínez', role: 'asesor' }
        ]
    };
    
    const user = users[role]?.find(u => u.username === username && u.password === password);
    
    if (user) {
        req.session.user = user;
        res.json({ success: true, user });
    } else {
        res.status(401).json({ success: false, message: 'Credenciales incorrectas' });
    }
});

app.get('/api/logout', (req, res) => {
    req.session.destroy();
    res.redirect('/pages/login');
});

// Middleware de autenticación para páginas protegidas
const requireAuth = (req, res, next) => {
    if (!req.session.user) {
        return res.redirect('/pages/login');
    }
    next();
};

// Middleware de permisos
const requirePermission = (permission) => {
    return (req, res, next) => {
        const permissions = {
            superadmin: ['dashboard', 'registros', 'estadisticas', 'mapa', 'analisis', 'admin', 'reportes', 'config', 'backup', 'delete'],
            admin: ['dashboard', 'registros', 'estadisticas', 'mapa', 'analisis', 'reportes', 'export'],
            asesor: ['dashboard', 'estadisticas', 'mapa', 'view']
        };
        
        const user = req.session.user;
        if (user && permissions[user.role]?.includes(permission)) {
            next();
        } else {
            res.status(403).render('pages/403', { title: 'Acceso Denegado' });
        }
    };
};

// Páginas protegidas
app.get('/pages/dashboard', requireAuth, (req, res) => {
    res.render('pages/dashboard', { 
        title: 'GTU Dashboard - Panel Principal',
        user: req.session.user
    });
});

app.get('/pages/admin', requireAuth, requirePermission('admin'), (req, res) => {
    res.render('pages/admin', { 
        title: 'GTU - Panel de Administración',
        user: req.session.user
    });
});

app.get('/pages/analisis', requireAuth, requirePermission('analisis'), (req, res) => {
    res.render('pages/analisis', { 
        title: 'GTU - Análisis Avanzado',
        user: req.session.user
    });
});

app.get('/pages/configuracion', requireAuth, requirePermission('config'), (req, res) => {
    res.render('pages/configuracion', { 
        title: 'GTU - Configuración',
        user: req.session.user
    });
});

app.get('/pages/estadisticas', requireAuth, (req, res) => {
    res.render('pages/estadisticas', { 
        title: 'GTU - Estadísticas',
        user: req.session.user
    });
});

app.get('/pages/filtros', requireAuth, (req, res) => {
    res.render('pages/filtros', { 
        title: 'GTU - Filtros Avanzados',
        user: req.session.user
    });
});

app.get('/pages/formulario', requireAuth, requirePermission('registros'), (req, res) => {
    res.render('pages/formulario', { 
        title: 'GTU - Formulario de Registro',
        user: req.session.user,
        editId: req.query.edit || null
    });
});

app.get('/pages/mapa', requireAuth, (req, res) => {
    res.render('pages/mapa', { 
        title: 'GTU - Mapa de Calor',
        user: req.session.user
    });
});

app.get('/pages/registros', requireAuth, requirePermission('registros'), (req, res) => {
    res.render('pages/registros', { 
        title: 'GTU - Registros',
        user: req.session.user
    });
});

app.get('/pages/reportes', requireAuth, requirePermission('reportes'), (req, res) => {
    res.render('pages/reportes', { 
        title: 'GTU - Reportes',
        user: req.session.user
    });
});

app.get('/pages/qr', requireAuth, (req, res) => {
    res.render('pages/qr', { 
        title: 'GTU - Generador QR',
        user: req.session.user
    });
});

// API endpoints para datos
app.get('/api/registros', requireAuth, (req, res) => {
    // Aquí se conectaría a una base de datos real
    // Por ahora, leer de localStorage en el cliente
    res.json({ message: 'Endpoint API para registros' });
});

app.post('/api/registros', requireAuth, requirePermission('registros'), (req, res) => {
    // Guardar registro en base de datos
    res.json({ success: true, message: 'Registro guardado' });
});

app.delete('/api/registros/:id', requireAuth, requirePermission('delete'), (req, res) => {
    // Eliminar registro
    res.json({ success: true, message: 'Registro eliminado' });
});

// Página 404
app.use((req, res) => {
    res.status(404).render('pages/404', { title: 'Página no encontrada' });
});

// Iniciar servidor
app.listen(PORT, () => {
    console.log(`🚀 Servidor GTU corriendo en http://localhost:${PORT}`);
    console.log(`📊 Dashboard: http://localhost:${PORT}/pages/dashboard`);
    console.log(`🔐 Login: http://localhost:${PORT}/pages/login`);
});
