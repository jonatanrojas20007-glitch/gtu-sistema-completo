<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/admin-panel.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="role-<%= user.role %>">
    <!-- Dashboard Header -->
    <header class="dashboard-header">
        <div class="header-top">
            <div class="logo-section">
                <div class="logo">
                    <div class="logo-icon">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <h1>GTU <span>Admin Panel</span></h1>
                </div>
                <div class="system-info">
                    <span class="system-status active">
                        <i class="fas fa-circle"></i> Modo Administración
                    </span>
                </div>
            </div>

            <div class="user-info">
                <div class="user-details">
                    <div class="user-name" id="current-user"><%= user.name %></div>
                    <span class="user-role" id="current-role"><%= user.role %></span>
                </div>
                <div class="user-avatar" id="user-avatar">
                    <%= user.name.charAt(0) %>
                </div>
                <a href="/api/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Salir
                </a>
            </div>
        </div>

        <nav class="dashboard-nav">
            <div class="nav-menu">
                <a href="/pages/dashboard" class="nav-item">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a href="/pages/admin" class="nav-item active">
                    <i class="fas fa-cog"></i> Administración
                </a>
                <a href="/pages/estadisticas" class="nav-item">
                    <i class="fas fa-chart-pie"></i> Estadísticas
                </a>
                <a href="/pages/mapa" class="nav-item">
                    <i class="fas fa-map"></i> Mapa
                </a>
                <a href="/pages/registros" class="nav-item">
                    <i class="fas fa-database"></i> Registros
                </a>
            </div>
        </nav>
    </header>

    <!-- Main Admin Content -->
    <main class="admin-main">
        <!-- Welcome Banner -->
        <section class="admin-banner">
            <div class="banner-content">
                <h2><i class="fas fa-user-shield"></i> Panel de Administración GTU</h2>
                <p>Gestión completa del sistema de talentos universitarios</p>
                <div class="admin-stats">
                    <div class="admin-stat">
                        <i class="fas fa-users"></i>
                        <div>
                            <span class="stat-value" id="total-users">3</span>
                            <span class="stat-label">Usuarios</span>
                        </div>
                    </div>
                    <div class="admin-stat">
                        <i class="fas fa-user-graduate"></i>
                        <div>
                            <span class="stat-value" id="total-students">0</span>
                            <span class="stat-label">Estudiantes</span>
                        </div>
                    </div>
                    <div class="admin-stat">
                        <i class="fas fa-database"></i>
                        <div>
                            <span class="stat-value" id="total-size">0 KB</span>
                            <span class="stat-label">Datos</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quick Admin Actions -->
        <div class="admin-actions-grid">
            <div class="admin-action-card">
                <div class="action-icon">
                    <i class="fas fa-users-cog"></i>
                </div>
                <h3>Gestión de Usuarios</h3>
                <p>Crear, editar y eliminar usuarios del sistema</p>
                <button class="action-btn" onclick="window.location.href='/pages/configuracion'">
                    <i class="fas fa-arrow-right"></i> Administrar
                </button>
            </div>

            <div class="admin-action-card">
                <div class="action-icon">
                    <i class="fas fa-database"></i>
                </div>
                <h3>Backup de Datos</h3>
                <p>Respaldar y restaurar información del sistema</p>
                <button class="action-btn" onclick="window.location.href='/pages/configuracion'">
                    <i class="fas fa-arrow-right"></i> Gestionar
                </button>
            </div>

            <div class="admin-action-card">
                <div class="action-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3>Seguridad</h3>
                <p>Configurar permisos y políticas de acceso</p>
                <button class="action-btn" onclick="window.location.href='/pages/configuracion'">
                    <i class="fas fa-arrow-right"></i> Configurar
                </button>
            </div>

            <div class="admin-action-card">
                <div class="action-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <h3>Registros del Sistema</h3>
                <p>Ver actividad y logs del sistema</p>
                <button class="action-btn" id="view-logs">
                    <i class="fas fa-arrow-right"></i> Ver Logs
                </button>
            </div>
        </div>

        <!-- System Health Dashboard -->
        <div class="system-health-section">
            <h3><i class="fas fa-heartbeat"></i> Salud del Sistema</h3>
            <div class="health-grid">
                <div class="health-card storage">
                    <div class="health-header">
                        <h4><i class="fas fa-hdd"></i> Almacenamiento</h4>
                        <span class="health-status good">Bueno</span>
                    </div>
                    <div class="health-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 35%"></div>
                        </div>
                        <span class="progress-text">35% utilizado</span>
                    </div>
                </div>

                <div class="health-card performance">
                    <div class="health-header">
                        <h4><i class="fas fa-tachometer-alt"></i> Rendimiento</h4>
                        <span class="health-status excellent">Excelente</span>
                    </div>
                    <div class="health-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 85%"></div>
                        </div>
                        <span class="progress-text">85% óptimo</span>
                    </div>
                </div>

                <div class="health-card security">
                    <div class="health-header">
                        <h4><i class="fas fa-shield-alt"></i> Seguridad</h4>
                        <span class="health-status good">Bueno</span>
                    </div>
                    <div class="health-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 90%"></div>
                        </div>
                        <span class="progress-text">90% seguro</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent System Activity -->
        <div class="system-activity-section">
            <div class="section-header">
                <h3><i class="fas fa-history"></i> Actividad Reciente del Sistema</h3>
                <button class="btn-secondary" id="refresh-activity">
                    <i class="fas fa-sync-alt"></i> Actualizar
                </button>
            </div>
            
            <div class="activity-table-container">
                <table id="system-activity-table">
                    <thead>
                        <tr>
                            <th>Fecha/Hora</th>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Módulo</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody id="activity-table-body">
                        <tr>
                            <td><%= new Date().toLocaleDateString() %></td>
                            <td><strong>admin</strong></td>
                            <td>Inicio de sesión</td>
                            <td>Autenticación</td>
                            <td><span class="status-badge status-success">Éxito</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- System Maintenance -->
        <div class="maintenance-section">
            <h3><i class="fas fa-tools"></i> Mantenimiento del Sistema</h3>
            <div class="maintenance-actions">
                <button class="maintenance-btn" id="clear-cache">
                    <i class="fas fa-broom"></i>
                    <span>Limpiar Cache</span>
                </button>
                
                <button class="maintenance-btn" id="optimize-db">
                    <i class="fas fa-database"></i>
                    <span>Optimizar BD</span>
                </button>
            </div>
            
            <div class="maintenance-info">
                <div class="info-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <h4>Último Mantenimiento</h4>
                        <p id="last-maintenance">Nunca</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="admin-footer">
        <div class="footer-content">
            <div class="footer-left">
                <p>Sistema GTU Admin Panel v2.0</p>
                <p class="copyright">© 2024 Gestión de Talentos Universitarios</p>
            </div>
            <div class="footer-right">
                <div class="system-info-footer">
                    <span class="version"><i class="fas fa-code-branch"></i> v2.0.1</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/js/admin-panel.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html>
