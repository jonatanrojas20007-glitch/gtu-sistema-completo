<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/analisis.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="analisis-container">
        <!-- Header -->
        <header class="analisis-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-chart-network"></i>
                    <div>
                        <h1>Análisis Avanzado GTU</h1>
                        <p class="subtitle">Análisis predictivo y tendencias</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <span id="current-user"><%= user.name %></span>
                    <span class="role-badge" id="current-role"><%= user.role %></span>
                </div>
                <div class="header-actions">
                    <a href="/pages/dashboard" class="action-btn">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/api/logout" class="action-btn">
                        <i class="fas fa-sign-out-alt"></i> Salir
                    </a>
                </div>
            </div>
        </header>

        <!-- Filtros de Análisis -->
        <div class="filtros-avanzados">
            <h3><i class="fas fa-filter"></i> Filtros de Análisis</h3>
            <div class="filtros-grid">
                <div class="filtro-item">
                    <label for="periodo-analisis">
                        <i class="fas fa-calendar"></i> Período
                    </label>
                    <select id="periodo-analisis" class="filtro-select">
                        <option value="completo">Histórico completo</option>
                        <option value="anual">Último año</option>
                        <option value="semestral">Último semestre</option>
                        <option value="trimestral">Último trimestre</option>
                    </select>
                </div>
                
                <div class="filtro-item">
                    <label for="tipo-analisis">
                        <i class="fas fa-chart-bar"></i> Tipo
                    </label>
                    <select id="tipo-analisis" class="filtro-select">
                        <option value="tendencia">Análisis de tendencias</option>
                        <option value="comparativo">Análisis comparativo</option>
                        <option value="predictivo">Análisis predictivo</option>
                    </select>
                </div>
            </div>
            
            <div class="filtro-actions">
                <button class="btn-primary" id="aplicar-analisis">
                    <i class="fas fa-play"></i> Ejecutar Análisis
                </button>
                <button class="btn-secondary" id="exportar-analisis">
                    <i class="fas fa-file-export"></i> Exportar Resultados
                </button>
            </div>
        </div>

        <!-- Dashboard de Análisis -->
        <div class="analisis-dashboard">
            <!-- Análisis Predictivo -->
            <div class="analisis-section">
                <div class="section-header">
                    <h3><i class="fas fa-crystal-ball"></i> Análisis Predictivo</h3>
                </div>
                <div class="analisis-content">
                    <div class="chart-container">
                        <canvas id="predictivoChart"></canvas>
                    </div>
                    <div class="analisis-resultados">
                        <div class="resultados-grid">
                            <div class="resultado-card">
                                <div class="resultado-icon">
                                    <i class="fas fa-arrow-up"></i>
                                </div>
                                <div class="resultado-content">
                                    <h5>Tendencia</h5>
                                    <p class="resultado-valor" id="tendencia-valor">--%</p>
                                </div>
                            </div>
                            <div class="resultado-card">
                                <div class="resultado-icon">
                                    <i class="fas fa-calendar-check"></i>
                                </div>
                                <div class="resultado-content">
                                    <h5>Próximo mes</h5>
                                    <p class="resultado-valor" id="proximo-mes">--</p>
                                </div>
                            </div>
                            <div class="resultado-card">
                                <div class="resultado-icon">
                                    <i class="fas fa-bullseye"></i>
                                </div>
                                <div class="resultado-content">
                                    <h5>Precisión</h5>
                                    <p class="resultado-valor" id="precision-modelo">--%</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Análisis Comparativo -->
            <div class="analisis-section">
                <div class="section-header">
                    <h3><i class="fas fa-balance-scale"></i> Análisis Comparativo</h3>
                </div>
                <div class="analisis-content">
                    <div class="comparativo-controls">
                        <div class="control-group">
                            <label for="variable-x">
                                <i class="fas fa-chart-line"></i> Variable X
                            </label>
                            <select id="variable-x" class="control-select">
                                <option value="carrera">Carrera</option>
                                <option value="escuela">Escuela</option>
                                <option value="municipio">Municipio</option>
                            </select>
                        </div>
                        <div class="control-group">
                            <label for="variable-y">
                                <i class="fas fa-chart-bar"></i> Variable Y
                            </label>
                            <select id="variable-y" class="control-select">
                                <option value="total">Total estudiantes</option>
                                <option value="crecimiento">Tasa de crecimiento</option>
                            </select>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="comparativoChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Análisis de Correlación -->
            <div class="analisis-section">
                <div class="section-header">
                    <h3><i class="fas fa-project-diagram"></i> Análisis de Correlación</h3>
                </div>
                <div class="analisis-content">
                    <div class="correlacion-matrix">
                        <table id="correlacion-table">
                            <thead>
                                <tr>
                                    <th>Variable</th>
                                    <th>Carrera</th>
                                    <th>Escuela</th>
                                    <th>Municipio</th>
                                    <th>Género</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th>Carrera</th>
                                    <td class="correlacion-cell">1.00</td>
                                    <td class="correlacion-cell">0.45</td>
                                    <td class="correlacion-cell">0.32</td>
                                    <td class="correlacion-cell">0.18</td>
                                </tr>
                                <tr>
                                    <th>Escuela</th>
                                    <td class="correlacion-cell">0.45</td>
                                    <td class="correlacion-cell">1.00</td>
                                    <td class="correlacion-cell">0.67</td>
                                    <td class="correlacion-cell">0.25</td>
                                </tr>
                                <tr>
                                    <th>Municipio</th>
                                    <td class="correlacion-cell">0.32</td>
                                    <td class="correlacion-cell">0.67</td>
                                    <td class="correlacion-cell">1.00</td>
                                    <td class="correlacion-cell">0.12</td>
                                </tr>
                                <tr>
                                    <th>Género</th>
                                    <td class="correlacion-cell">0.18</td>
                                    <td class="correlacion-cell">0.25</td>
                                    <td class="correlacion-cell">0.12</td>
                                    <td class="correlacion-cell">1.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Insights -->
            <div class="analisis-section">
                <div class="section-header">
                    <h3><i class="fas fa-lightbulb"></i> Insights</h3>
                </div>
                <div class="insights-container">
                    <div class="insight-card positive">
                        <div class="insight-icon">
                            <i class="fas fa-thumbs-up"></i>
                        </div>
                        <div class="insight-content">
                            <h4>Fortaleza identificada</h4>
                            <p>Las carreras de tecnología muestran crecimiento constante.</p>
                        </div>
                    </div>
                    
                    <div class="insight-card warning">
                        <div class="insight-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div class="insight-content">
                            <h4>Oportunidad de mejora</h4>
                            <p>Baja representación femenina en ingenierías.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="analisis-footer">
            <div class="footer-left">
                <p><i class="fas fa-brain"></i> Análisis Avanzado GTU</p>
                <p class="timestamp">Última ejecución: <span id="last-execution">--:--:--</span></p>
            </div>
            <div class="footer-right">
                <div class="model-info">
                    <span class="model-tag">
                        <i class="fas fa-robot"></i> Modelo: Regresión Lineal
                    </span>
                </div>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="/js/analisis.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html>
