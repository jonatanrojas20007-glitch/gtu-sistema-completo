<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/reportes.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="reportes-container">
        <!-- Header -->
        <header class="reportes-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-file-alt"></i>
                    <div>
                        <h1>Reportes GTU</h1>
                        <p class="subtitle">Sistema de generación y análisis de reportes</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <span id="current-user"><%= user.name %></span>
                    <span class="role-badge" id="current-role"><%= user.role %></span>
                </div>
                <div class="header-actions">
                    <button class="action-btn" id="refresh-reports">
                        <i class="fas fa-sync-alt"></i> Actualizar
                    </button>
                    <a href="/pages/dashboard" class="action-btn">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/api/logout" class="action-btn">
                        <i class="fas fa-sign-out-alt"></i> Salir
                    </a>
                </div>
            </div>
        </header>

        <!-- Sección de Reportes -->
        <div id="reports-section">
            <!-- Filtros de Reportes -->
            <div class="filters-section">
                <div class="filters-header">
                    <h3><i class="fas fa-filter"></i> Filtros del Reporte</h3>
                    <button class="btn-primary" id="generate-report">
                        <i class="fas fa-magic"></i> Generar Reporte
                    </button>
                </div>
                
                <div class="filters-grid">
                    <div class="filter-group">
                        <label for="report-type">
                            <i class="fas fa-file-alt"></i> Tipo de Reporte
                        </label>
                        <select id="report-type" class="filter-select">
                            <option value="general">Reporte General</option>
                            <option value="academico">Reporte Académico</option>
                            <option value="geografico">Reporte Geográfico</option>
                            <option value="tendencia">Reporte de Tendencia</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="date-range">
                            <i class="fas fa-calendar-alt"></i> Rango de Fechas
                        </label>
                        <select id="date-range" class="filter-select">
                            <option value="all">Todo el período</option>
                            <option value="today">Hoy</option>
                            <option value="week">Última semana</option>
                            <option value="month">Último mes</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="format">
                            <i class="fas fa-download"></i> Formato
                        </label>
                        <select id="format" class="filter-select">
                            <option value="html">HTML (Vista web)</option>
                            <option value="pdf">PDF</option>
                            <option value="excel">Excel (CSV)</option>
                        </select>
                    </div>
                </div>
                
                <!-- Filtros avanzados -->
                <div class="advanced-filters">
                    <h4><i class="fas fa-sliders-h"></i> Filtros Avanzados</h4>
                    <div class="advanced-grid">
                        <div class="advanced-filter">
                            <label for="carrera-filter">
                                <i class="fas fa-graduation-cap"></i> Carrera
                            </label>
                            <select id="carrera-filter" class="filter-select">
                                <option value="">Todas las carreras</option>
                            </select>
                        </div>
                        
                        <div class="advanced-filter">
                            <label for="escuela-filter">
                                <i class="fas fa-school"></i> Escuela
                            </label>
                            <select id="escuela-filter" class="filter-select">
                                <option value="">Todas las escuelas</option>
                            </select>
                        </div>
                        
                        <div class="advanced-filter">
                            <label for="genero-filter">
                                <i class="fas fa-venus-mars"></i> Género
                            </label>
                            <select id="genero-filter" class="filter-select">
                                <option value="">Todos</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vista Previa del Reporte -->
            <div class="report-preview">
                <div class="preview-header">
                    <h3><i class="fas fa-eye"></i> Vista Previa</h3>
                    <div class="preview-actions">
                        <button class="btn-secondary" id="print-report">
                            <i class="fas fa-print"></i> Imprimir
                        </button>
                        <button class="btn-primary" id="export-report">
                            <i class="fas fa-download"></i> Exportar
                        </button>
                    </div>
                </div>
                
                <div class="preview-content" id="report-content">
                    <div class="report-content">
                        <div class="report-header">
                            <h2>Reporte General GTU</h2>
                            <div class="report-meta">
                                <p>Generado: <%= new Date().toLocaleDateString() %></p>
                            </div>
                        </div>
                        
                        <div class="report-summary">
                            <div class="summary-grid">
                                <div class="summary-item">
                                    <h4>Total Estudiantes</h4>
                                    <div class="value">0</div>
                                </div>
                                <div class="summary-item">
                                    <h4>Escuelas</h4>
                                    <div class="value">0</div>
                                </div>
                                <div class="summary-item">
                                    <h4>Carreras</h4>
                                    <div class="value">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Estadísticas Rápidas -->
            <div class="quick-stats">
                <h3><i class="fas fa-chart-pie"></i> Estadísticas Rápidas</h3>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="stat-content">
                            <h4>Total Estudiantes</h4>
                            <p class="stat-value" id="stat-total">0</p>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-university"></i>
                        </div>
                        <div class="stat-content">
                            <h4>Escuelas</h4>
                            <p class="stat-value" id="stat-escuelas">0</p>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <div class="stat-content">
                            <h4>Carreras</h4>
                            <p class="stat-value" id="stat-carreras">0</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="reportes-footer">
            <div class="footer-left">
                <p><i class="fas fa-file-alt"></i> Sistema de Reportes GTU</p>
                <p class="timestamp">Última actualización: <span id="last-update">--:--:--</span></p>
            </div>
            <div class="footer-right">
                <div class="report-info">
                    <span class="report-count">Reportes: <span id="total-reports">0</span></span>
                </div>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="/js/reportes.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html>
