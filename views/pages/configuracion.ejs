<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/configuracion.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="config-container">
        <!-- Header -->
        <header class="config-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-cogs"></i>
                    <div>
                        <h1>Configuración GTU</h1>
                        <p class="subtitle">Panel de control del sistema</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <span id="current-user"><%= user.name %></span>
                    <span class="role-badge" id="current-role"><%= user.role %></span>
                </div>
                <div class="header-actions">
                    <a href="/pages/dashboard" class="action-btn">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/api/logout" class="action-btn">
                        <i class="fas fa-sign-out-alt"></i> Salir
                    </a>
                </div>
            </div>
        </header>

        <!-- Sistema de Pestañas -->
        <div class="config-tabs">
            <button class="tab-btn active" data-tab="general">
                <i class="fas fa-sliders-h"></i> General
            </button>
            <button class="tab-btn" data-tab="usuarios">
                <i class="fas fa-users-cog"></i> Usuarios
            </button>
            <button class="tab-btn" data-tab="dashboard">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </button>
            <button class="tab-btn" data-tab="formulario">
                <i class="fas fa-edit"></i> Formulario
            </button>
            <button class="tab-btn" data-tab="estadisticas">
                <i class="fas fa-chart-bar"></i> Estadísticas
            </button>
            <button class="tab-btn" data-tab="mapa">
                <i class="fas fa-map"></i> Mapa
            </button>
            <button class="tab-btn" data-tab="seguridad">
                <i class="fas fa-shield-alt"></i> Seguridad
            </button>
            <button class="tab-btn" data-tab="backup">
                <i class="fas fa-database"></i> Backup
            </button>
        </div>

        <!-- Contenido de Configuración -->
        <div class="config-content">
            <!-- Pestaña General -->
            <div class="tab-content active" id="general-tab">
                <h2><i class="fas fa-sliders-h"></i> Configuración General</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-info-circle"></i> Información del Sistema</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="system-name">
                                <i class="fas fa-university"></i> Nombre del Sistema
                            </label>
                            <input type="text" id="system-name" value="GTU - Gestión de Talentos Universitarios">
                        </div>
                        
                        <div class="form-group">
                            <label for="system-version">
                                <i class="fas fa-code-branch"></i> Versión
                            </label>
                            <input type="text" id="system-version" value="2.0.1" readonly>
                        </div>
                    </div>
                </div>
                
                <div class="config-section">
                    <h3><i class="fas fa-palette"></i> Apariencia</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="theme-color">
                                <i class="fas fa-fill-drip"></i> Color Principal
                            </label>
                            <input type="color" id="theme-color" value="#FF6B35">
                        </div>
                        
                        <div class="form-group">
                            <label for="theme-mode">
                                <i class="fas fa-adjust"></i> Modo de Tema
                            </label>
                            <select id="theme-mode">
                                <option value="light" selected>Claro</option>
                                <option value="dark">Oscuro</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Usuarios -->
            <div class="tab-content" id="usuarios-tab">
                <h2><i class="fas fa-users-cog"></i> Gestión de Usuarios</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-user-plus"></i> Nuevo Usuario</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="new-username">
                                <i class="fas fa-user"></i> Usuario
                            </label>
                            <input type="text" id="new-username" placeholder="ej: juan.perez">
                        </div>
                        
                        <div class="form-group">
                            <label for="new-email">
                                <i class="fas fa-envelope"></i> Email
                            </label>
                            <input type="email" id="new-email" placeholder="usuario@ejemplo.com">
                        </div>
                        
                        <div class="form-group">
                            <label for="new-role">
                                <i class="fas fa-user-tag"></i> Rol
                            </label>
                            <select id="new-role">
                                <option value="admin">Administrador</option>
                                <option value="asesor">Asesor</option>
                            </select>
                        </div>
                    </div>
                    
                    <button class="btn-primary" id="add-user">
                        <i class="fas fa-user-plus"></i> Agregar Usuario
                    </button>
                </div>
                
                <div class="config-section">
                    <h3><i class="fas fa-list"></i> Usuarios Registrados</h3>
                    <div class="users-table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Usuario</th>
                                    <th>Nombre</th>
                                    <th>Rol</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="users-list">
                                <tr>
                                    <td>admin</td>
                                    <td>Super Admin</td>
                                    <td><span class="role-badge">superadmin</span></td>
                                    <td>
                                        <button class="btn-icon"><i class="fas fa-edit"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>directora</td>
                                    <td>Directora García</td>
                                    <td><span class="role-badge">admin</span></td>
                                    <td>
                                        <button class="btn-icon"><i class="fas fa-edit"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Pestaña Dashboard -->
            <div class="tab-content" id="dashboard-tab">
                <h2><i class="fas fa-tachometer-alt"></i> Configuración del Dashboard</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-columns"></i> Widgets</h3>
                    <div class="widgets-control">
                        <div class="widgets-list">
                            <div class="widget-item">
                                <input type="checkbox" id="widget-stats" checked>
                                <label for="widget-stats">
                                    <i class="fas fa-chart-bar"></i>
                                    <span>Estadísticas Principales</span>
                                </label>
                            </div>
                            
                            <div class="widget-item">
                                <input type="checkbox" id="widget-activity" checked>
                                <label for="widget-activity">
                                    <i class="fas fa-history"></i>
                                    <span>Actividad Reciente</span>
                                </label>
                            </div>
                            
                            <div class="widget-item">
                                <input type="checkbox" id="widget-quick-actions" checked>
                                <label for="widget-quick-actions">
                                    <i class="fas fa-bolt"></i>
                                    <span>Acciones Rápidas</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Formulario -->
            <div class="tab-content" id="formulario-tab">
                <h2><i class="fas fa-edit"></i> Configuración del Formulario</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-toggle-on"></i> Campos del Formulario</h3>
                    <div class="fields-control">
                        <div class="fields-list">
                            <div class="field-item">
                                <input type="checkbox" id="field-nombre" checked disabled>
                                <label for="field-nombre">
                                    <i class="fas fa-user"></i>
                                    <span>Nombre Completo</span>
                                </label>
                            </div>
                            
                            <div class="field-item">
                                <input type="checkbox" id="field-escuela" checked>
                                <label for="field-escuela">
                                    <i class="fas fa-school"></i>
                                    <span>Escuela</span>
                                </label>
                            </div>
                            
                            <div class="field-item">
                                <input type="checkbox" id="field-carrera" checked>
                                <label for="field-carrera">
                                    <i class="fas fa-graduation-cap"></i>
                                    <span>Carrera de Interés</span>
                                </label>
                            </div>
                            
                            <div class="field-item">
                                <input type="checkbox" id="field-municipio" checked>
                                <label for="field-municipio">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>Municipio</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Estadísticas -->
            <div class="tab-content" id="estadisticas-tab">
                <h2><i class="fas fa-chart-bar"></i> Configuración de Estadísticas</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-chart-pie"></i> Gráficos</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="chart-type">
                                <i class="fas fa-chart-bar"></i> Tipo de Gráfico
                            </label>
                            <select id="chart-type">
                                <option value="bar">Barras</option>
                                <option value="pie" selected>Pastel</option>
                                <option value="line">Líneas</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Mapa -->
            <div class="tab-content" id="mapa-tab">
                <h2><i class="fas fa-map"></i> Configuración del Mapa</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-map-marked-alt"></i> Ubicación</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="map-zoom">
                                <i class="fas fa-search-plus"></i> Zoom
                            </label>
                            <input type="range" id="map-zoom" min="1" max="15" value="9">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Seguridad -->
            <div class="tab-content" id="seguridad-tab">
                <h2><i class="fas fa-shield-alt"></i> Configuración de Seguridad</h2>
                
                <div class="config-section">
                    <h3><i class="fas fa-lock"></i> Autenticación</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="session-timeout">
                                <i class="fas fa-clock"></i> Tiempo de Sesión
                            </label>
                            <select id="session-timeout">
                                <option value="30" selected>30 minutos</option>
                                <option value="60">1 hora</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pestaña Backup -->
            <div class="tab-content" id="backup-tab">
                <h2><i class="fas fa-database"></i> Backup</h2>
                
                <div class="config-section">
                    <div class="backup-options">
                        <div class="backup-card">
                            <div class="backup-icon">
                                <i class="fas fa-download"></i>
                            </div>
                            <h4>Descargar Backup</h4>
                            <button class="btn-primary" id="backup-now">
                                <i class="fas fa-download"></i> Crear Backup
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de Estado -->
        <div class="config-status">
            <div class="status-left">
                <i class="fas fa-circle" id="config-status-icon" style="color: #27ae60;"></i>
                <span id="config-status-text">Configuración cargada</span>
            </div>
            <div class="status-right">
                <button class="btn-primary" id="save-all-config">
                    <i class="fas fa-save"></i> Guardar Todo
                </button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/js/configuracion.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html>
