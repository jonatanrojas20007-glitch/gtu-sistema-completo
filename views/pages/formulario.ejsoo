<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/formulario.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="formulario-container">
        <!-- Header -->
        <header class="formulario-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-user-shield"></i>
                    <div>
                        <h1>Sistema de Registro GTU</h1>
                        <p class="subtitle">Formulario Seguro - Tus datos están protegidos</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="security-badge">
                    <i class="fas fa-lock"></i>
                    <span>Conexión Segura</span>
                </div>
                <a href="/pages/dashboard" class="action-btn">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/api/logout" class="action-btn">
                    <i class="fas fa-sign-out-alt"></i> Salir
                </a>
            </div>
        </header>

        <!-- Barra de Progreso -->
        <div class="progress-container">
            <div class="progress-header">
                <h3><i class="fas fa-tasks"></i> Progreso del Formulario</h3>
                <span id="progress-percentage">0%</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
            </div>
            <div class="progress-steps">
                <div class="step active" data-step="1">
                    <div class="step-number">1</div>
                    <div class="step-label">Datos Personales</div>
                </div>
                <div class="step" data-step="2">
                    <div class="step-number">2</div>
                    <div class="step-label">Información Académica</div>
                </div>
                <div class="step" data-step="3">
                    <div class="step-number">3</div>
                    <div class="step-label">Ubicación</div>
                </div>
                <div class="step" data-step="4">
                    <div class="step-number">4</div>
                    <div class="step-label">Finalizar</div>
                </div>
            </div>
        </div>

        <!-- Formulario -->
        <main class="formulario-main">
            <form id="registro-form" class="registro-form">
                <!-- Sección 1: Datos Personales -->
                <div class="form-section" data-section="1">
                    <h2><i class="fas fa-id-card"></i> 1. Datos Personales</h2>
                    <p class="section-description">Información básica para tu identificación en el sistema</p>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="nombre">
                                <i class="fas fa-user"></i> Nombre(s) *
                            </label>
                            <input type="text" id="nombre" required placeholder="Ej: Juan Carlos">
                            <div class="field-progress" data-field="nombre"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="apellido-paterno">
                                <i class="fas fa-user"></i> Apellido Paterno *
                            </label>
                            <input type="text" id="apellido-paterno" required placeholder="Ej: Pérez">
                            <div class="field-progress" data-field="apellido-paterno"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="apellido-materno">
                                <i class="fas fa-user"></i> Apellido Materno *
                            </label>
                            <input type="text" id="apellido-materno" required placeholder="Ej: García">
                            <div class="field-progress" data-field="apellido-materno"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="telefono">
                                <i class="fas fa-phone"></i> Teléfono *
                            </label>
                            <input type="tel" id="telefono" required placeholder="Ej: 4421234567" 
                                   pattern="[0-9]{10}" maxlength="10">
                            <small class="form-help">10 dígitos sin espacios</small>
                            <div class="field-progress" data-field="telefono"></div>
                        </div>
                    </div>
                </div>

                <!-- Sección 2: Información Académica -->
                <div class="form-section" data-section="2">
                    <h2><i class="fas fa-graduation-cap"></i> 2. Información Académica</h2>
                    <p class="section-description">Detalles sobre tu formación educativa</p>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="nivel-educativo">
                                <i class="fas fa-school"></i> Nivel Educativo *
                            </label>
                            <select id="nivel-educativo" required>
                                <option value="">Seleccionar nivel...</option>
                                <option value="Primaria">Primaria</option>
                                <option value="Secundaria">Secundaria</option>
                                <option value="Preparatoria/Bachillerato">Preparatoria/Bachillerato</option>
                                <option value="Universidad">Universidad</option>
                                <option value="Posgrado">Posgrado</option>
                            </select>
                            <div class="field-progress" data-field="nivel-educativo"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="escuela">
                                <i class="fas fa-university"></i> Escuela de Procedencia *
                            </label>
                            <input type="text" id="escuela" required placeholder="Ej: Escuela Benito Juárez">
                            <div class="field-progress" data-field="escuela"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="carrera">
                                <i class="fas fa-book"></i> Carrera de Interés *
                            </label>
                            <select id="carrera" required>
                                <option value="">Seleccionar carrera...</option>
                                <optgroup label="Ingenierías">
                                    <option value="Ingeniería en Sistemas">Ingeniería en Sistemas</option>
                                    <option value="Ingeniería Civil">Ingeniería Civil</option>
                                    <option value="Ingeniería Industrial">Ingeniería Industrial</option>
                                </optgroup>
                                <optgroup label="Ciencias de la Salud">
                                    <option value="Medicina">Medicina</option>
                                    <option value="Enfermería">Enfermería</option>
                                    <option value="Psicología">Psicología</option>
                                </optgroup>
                                <optgroup label="Ciencias Sociales">
                                    <option value="Derecho">Derecho</option>
                                    <option value="Administración">Administración</option>
                                    <option value="Contabilidad">Contabilidad</option>
                                </optgroup>
                            </select>
                            <div class="field-progress" data-field="carrera"></div>
                        </div>
                    </div>
                </div>

                <!-- Sección 3: Ubicación -->
                <div class="form-section" data-section="3">
                    <h2><i class="fas fa-map-marker-alt"></i> 3. Ubicación</h2>
                    <p class="section-description">Información geográfica para análisis regional</p>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="municipio">
                                <i class="fas fa-city"></i> Municipio *
                            </label>
                            <select id="municipio" required>
                                <option value="">Seleccionar municipio...</option>
                                <option value="Querétaro">Querétaro</option>
                                <option value="San Juan del Río">San Juan del Río</option>
                                <option value="El Marqués">El Marqués</option>
                                <option value="Corregidora">Corregidora</option>
                            </select>
                            <div class="field-progress" data-field="municipio"></div>
                        </div>
                    </div>
                </div>

                <!-- Términos y Condiciones -->
                <div class="form-section terms-section">
                    <div class="terms-card">
                        <div class="terms-check">
                            <input type="checkbox" id="terms" required>
                            <label for="terms">
                                He leído y acepto los términos y condiciones del sistema GTU
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="form-actions">
                    <button type="submit" class="btn-primary" id="submit-btn" disabled>
                        <i class="fas fa-paper-plane"></i> Enviar Registro
                    </button>
                    <button type="reset" class="btn-secondary">
                        <i class="fas fa-redo"></i> Limpiar Formulario
                    </button>
                </div>
            </form>
        </main>

        <!-- Footer -->
        <footer class="formulario-footer">
            <div class="footer-security">
                <p class="security-statement">
                    <strong>Sistema 100% Seguro</strong> - Tus datos están protegidos
                </p>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="/js/formulario.js"></script>
    <script>
        // Pasar datos del usuario al JS
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html><!DOCTYPE html>
