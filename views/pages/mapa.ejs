<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/mapa.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map {
            height: 500px;
            width: 100%;
            border-radius: 15px;
            z-index: 1;
        }
        .leaflet-container {
            border-radius: 15px;
        }
    </style>
</head>
<body>
    <div class="mapa-container">
        <!-- Header -->
        <header class="mapa-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-map-marked-alt"></i>
                    <div>
                        <h1>Mapa de Calor Querétaro</h1>
                        <p class="subtitle">Distribución geográfica de estudiantes GTU</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <span id="current-user"><%= user.name %></span>
                    <span class="role-badge" id="current-role"><%= user.role %></span>
                </div>
                <div class="header-actions">
                    <button class="action-btn" id="refresh-map">
                        <i class="fas fa-sync-alt"></i> Actualizar
                    </button>
                    <a href="/pages/dashboard" class="action-btn">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/api/logout" class="action-btn">
                        <i class="fas fa-sign-out-alt"></i> Salir
                    </a>
                </div>
            </div>
        </header>

        <!-- Controles del Mapa -->
        <div class="map-controls">
            <div class="control-group">
                <h3><i class="fas fa-sliders-h"></i> Controles del Mapa</h3>
                <div class="controls-grid">
                    <div class="control-item">
                        <label for="map-type">
                            <i class="fas fa-layer-group"></i> Tipo de Mapa
                        </label>
                        <select id="map-type" class="control-select">
                            <option value="heatmap">Mapa de Calor</option>
                            <option value="markers">Marcadores</option>
                        </select>
                    </div>
                    
                    <div class="control-item">
                        <label for="radius">
                            <i class="fas fa-expand-alt"></i> Radio
                        </label>
                        <div class="slider-container">
                            <input type="range" id="radius" min="10" max="50" value="25" class="slider">
                            <span id="radius-value">25</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="filters-panel">
                <h3><i class="fas fa-search"></i> Filtros</h3>
                <div class="filters-grid">
                    <div class="filter-item">
                        <label for="carrera-filter">
                            <i class="fas fa-graduation-cap"></i> Carrera
                        </label>
                        <select id="carrera-filter" class="filter-select">
                            <option value="">Todas las carreras</option>
                        </select>
                    </div>
                    
                    <div class="filter-item">
                        <label for="municipio-filter">
                            <i class="fas fa-map-marker-alt"></i> Municipio
                        </label>
                        <select id="municipio-filter" class="filter-select">
                            <option value="">Todos los municipios</option>
                        </select>
                    </div>
                </div>
                
                <div class="filter-actions">
                    <button class="btn-primary" id="apply-filters">
                        <i class="fas fa-check"></i> Aplicar Filtros
                    </button>
                    <button class="btn-secondary" id="reset-filters">
                        <i class="fas fa-redo"></i> Restablecer
                    </button>
                </div>
            </div>
        </div>

        <!-- Mapa Principal -->
        <div class="map-section">
            <div class="map-header">
                <h2><i class="fas fa-map"></i> Mapa de Calor - Estado de Querétaro</h2>
                <div class="map-stats">
                    <div class="stat">
                        <span class="stat-label">Estudiantes:</span>
                        <span class="stat-value" id="total-estudiantes">0</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Municipios:</span>
                        <span class="stat-value" id="total-municipios">0</span>
                    </div>
                </div>
            </div>
            
            <!-- Contenedor del mapa -->
            <div id="map"></div>
            
            <!-- Mensaje cuando no hay datos -->
            <div id="map-empty" style="display: none; text-align: center; padding: 50px;">
                <i class="fas fa-map" style="font-size: 48px; color: #ccc;"></i>
                <h3>No hay datos para mostrar</h3>
                <p>Completa el formulario de registro para ver el mapa de calor.</p>
            </div>
        </div>

        <!-- Footer -->
        <footer class="mapa-footer">
            <div class="footer-left">
                <p><i class="fas fa-map-marker-alt"></i> Estado de Querétaro, México</p>
            </div>
            <div class="footer-right">
                <p><i class="fas fa-sync-alt"></i> Última actualización: <span id="last-update">--:--:--</span></p>
            </div>
        </footer>
    </div>

    <!-- Scripts - Orden correcto: primero Leaflet, luego heat, luego mapa.js -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/mapa.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
        
        // Inicializar el mapa cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM cargado, inicializando mapa...');
            if (window.mapaQueretaro) {
                window.mapaQueretaro.init();
            } else {
                console.log('Esperando a que mapa.js se cargue...');
                setTimeout(function() {
                    if (window.mapaQueretaro) {
                        window.mapaQueretaro.init();
                    }
                }, 500);
            }
        });
    </script>
</body>
</html>
