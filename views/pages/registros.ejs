<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GTU</title>
    <link rel="stylesheet" href="/css/registros.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="registros-container">
        <!-- Header -->
        <header class="registros-header">
            <div class="header-left">
                <div class="logo">
                    <i class="fas fa-database"></i>
                    <div>
                        <h1>Registros GTU</h1>
                        <p class="subtitle">Gestión completa de estudiantes registrados</p>
                    </div>
                </div>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <span id="current-user"><%= user.name %></span>
                    <span class="role-badge" id="current-role"><%= user.role %></span>
                </div>
                <div class="header-actions">
                    <button class="action-btn" id="refresh-data">
                        <i class="fas fa-sync-alt"></i> Actualizar
                    </button>
                    <a href="/pages/dashboard" class="action-btn">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a href="/pages/formulario" class="action-btn primary">
                        <i class="fas fa-user-plus"></i> Nuevo
                    </a>
                    <a href="/api/logout" class="action-btn">
                        <i class="fas fa-sign-out-alt"></i> Salir
                    </a>
                </div>
            </div>
        </header>

        <!-- Estadísticas Rápidas -->
        <div class="quick-stats">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-user-graduate"></i>
                </div>
                <div class="stat-content">
                    <h3>Total Registros</h3>
                    <p class="stat-value" id="total-registros">0</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-calendar-day"></i>
                </div>
                <div class="stat-content">
                    <h3>Registros Hoy</h3>
                    <p class="stat-value" id="registros-hoy">0</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-university"></i>
                </div>
                <div class="stat-content">
                    <h3>Escuelas Únicas</h3>
                    <p class="stat-value" id="escuelas-unicas">0</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div class="stat-content">
                    <h3>Carreras Únicas</h3>
                    <p class="stat-value" id="carreras-unicas">0</p>
                </div>
            </div>
        </div>

        <!-- Panel de Control -->
        <div class="control-panel">
            <div class="search-section">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="global-search" placeholder="Buscar en todos los campos...">
                    <button class="search-clear" id="clear-search">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                
                <div class="search-filters">
                    <div class="filter-group">
                        <label for="filter-carrera"><i class="fas fa-graduation-cap"></i> Carrera</label>
                        <select id="filter-carrera" class="filter-select">
                            <option value="">Todas las carreras</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="filter-escuela"><i class="fas fa-school"></i> Escuela</label>
                        <select id="filter-escuela" class="filter-select">
                            <option value="">Todas las escuelas</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="filter-municipio"><i class="fas fa-map-marker-alt"></i> Municipio</label>
                        <select id="filter-municipio" class="filter-select">
                            <option value="">Todos los municipios</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="action-buttons">
                <button class="btn-secondary" id="export-csv">
                    <i class="fas fa-file-csv"></i> Exportar CSV
                </button>
                <button class="btn-primary" id="apply-filters">
                    <i class="fas fa-filter"></i> Aplicar Filtros
                </button>
                <button class="btn-secondary" id="reset-filters">
                    <i class="fas fa-redo"></i> Limpiar Filtros
                </button>
            </div>
        </div>

        <!-- Tabla de Registros -->
        <div class="registros-table-container">
            <div class="table-header">
                <h3><i class="fas fa-table"></i> Registros de Estudiantes 
                    (<span id="table-count">0</span>)
                </h3>
                <div class="table-actions">
                    <div class="rows-per-page">
                        <label for="rows-per-page">Filas:</label>
                        <select id="rows-per-page" class="page-select">
                            <option value="10">10</option>
                            <option value="25" selected>25</option>
                            <option value="50">50</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="table-wrapper">
                <table id="registros-table">
                    <thead>
                        <tr>
                            <th class="select-col">
                                <input type="checkbox" id="select-all">
                            </th>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Escuela</th>
                            <th>Carrera</th>
                            <th>Municipio</th>
                            <th>Género</th>
                            <th>Fecha</th>
                            <th class="actions-col">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="registros-body">
                        <!-- Datos cargados dinámicamente -->
                    </tbody>
                </table>
                
                <!-- Estado vacío -->
                <div id="empty-table" class="empty-table-state">
                    <div class="empty-icon">
                        <i class="fas fa-database"></i>
                    </div>
                    <h3>No hay registros aún</h3>
                    <p>Los registros aparecerán aquí cuando los estudiantes completen el formulario.</p>
                    <div class="empty-actions">
                        <a href="/pages/formulario" class="btn-primary">
                            <i class="fas fa-plus"></i> Crear Primer Registro
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Paginación -->
            <div class="pagination-container">
                <div class="pagination-info-bottom">
                    Mostrando <span id="showing-from">0</span>-<span id="showing-to">0</span> de 
                    <span id="total-rows">0</span> registros
                </div>
                <div class="pagination-controls">
                    <button class="pagination-btn" id="first-page" disabled>
                        <i class="fas fa-angle-double-left"></i>
                    </button>
                    <button class="pagination-btn" id="prev-page" disabled>
                        <i class="fas fa-angle-left"></i>
                    </button>
                    
                    <div class="page-numbers" id="page-numbers">
                        <!-- Números de página dinámicos -->
                    </div>
                    
                    <button class="pagination-btn" id="next-page" disabled>
                        <i class="fas fa-angle-right"></i>
                    </button>
                    <button class="pagination-btn" id="last-page" disabled>
                        <i class="fas fa-angle-double-right"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="registros-footer">
            <div class="footer-left">
                <p><i class="fas fa-info-circle"></i> Última actualización: <span id="last-update">--:--:--</span></p>
            </div>
            <div class="footer-right">
                <button class="btn-secondary" id="backup-data">
                    <i class="fas fa-save"></i> Backup
                </button>
            </div>
        </footer>
    </div>

    <!-- Modal de Detalles -->
    <div class="modal" id="details-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-user-graduate"></i> Detalles del Estudiante</h3>
                <button class="modal-close" id="close-modal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="modal-body">
                <!-- Contenido dinámico -->
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" id="edit-record">
                    <i class="fas fa-edit"></i> Editar
                </button>
                <button class="btn-primary" id="close-details">
                    <i class="fas fa-check"></i> Cerrar
                </button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/js/registros.js"></script>
    <script>
        window.currentUser = <%- JSON.stringify(user) %>;
    </script>
</body>
</html>
